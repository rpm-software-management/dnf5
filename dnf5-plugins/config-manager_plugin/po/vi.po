#: addrepo.cpp:136
#, c++-format
msgid "from-repofile: \"{}\" file does not exist"
msgstr "from-repofile: tệp \"{}\" không tồn tại"

#: addrepo.cpp:139
#, c++-format
msgid "from-repofile: {}"
msgstr "from-repofile: {}"

#: addrepo.cpp:169 setopt.cpp:83 setvar.cpp:49
#, c++-format
msgid "{}: Badly formatted argument value \"{}\""
msgstr "{}: Giá trị đối số \"{}\" được định dạng sai"

#: addrepo.cpp:179
#, c++-format
msgid "Cannot set repository option \"{}={}\": {}"
msgstr "Không thể thiết lập tùy chọn kho lưu trữ \"{}={}\": {}"

#: addrepo.cpp:187 setopt.cpp:138
#, c++-format
msgid "Sets the \"{}\" option again with a different value: \"{}\" != \"{}\""
msgstr "Đặt lại tùy chọn \"{}\" với một giá trị khác: \"{}\" ≠ \"{}\""

#: addrepo.cpp:253
msgid "Missing path to repository configuration directory"
msgstr "Thiếu đường dẫn tới thư mục cài đặt kho chứa"

#: addrepo.cpp:303
#, c++-format
msgid "Failed to copy repository configuration file \"{}\": {}"
msgstr "Không sao chép được tệp cấu hình kho lưu trữ \"{}\": {}"

#: addrepo.cpp:314
#, c++-format
msgid "Failed to download repository configuration file \"{}\": {}"
msgstr "Không thể tải xuống được tệp cấu hình kho lưu trữ \"{}\": {}"

#: addrepo.cpp:342
#, c++-format
msgid ""
"Error in added repository configuration file. Cannot set repository option "
"\"{}={}\": {}"
msgstr ""
"Lỗi trong tệp cấu hình kho lưu trữ đã thêm. Không thể thiết lập tùy chọn kho "
"lưu trữ \"{}={}\": {}"

#: addrepo.cpp:376
#, c++-format
msgid "Bad baseurl: {}={}"
msgstr "URL cơ sở không hợp lệ: {}={}"

#: addrepo.cpp:384
msgid ""
"One of --from-repofile=<URL>, --set=baseurl=<URL>, --set=mirrorlist=<URL>, --"
"set=metalink=<URL> must be set to a non-empty URL"
msgstr ""
"Phải thiết lập ít nhất một trong các tham số --from-repofile, --"
"set=baseurl, --set=mirrorlist, hoặc --set=metalink với một URL không được để "
"trống"

#: addrepo.cpp:429
#, c++-format
msgid "Failed to save repository configuration file \"{}\": {}"
msgstr "Không thể lưu tệp cấu hình kho lưu trữ \"{}\": {}"

#: addrepo.cpp:451
#, c++-format
msgid ""
"File \"{}\" already exists and configures repositories with IDs \"{}\". Add "
"\"--add-or-replace\" or \"--overwrite\"."
msgstr ""
"Tệp \"{}\" đã tồn tại và cấu hình các kho lưu trữ có ID là \"{}\". Hãy thêm "
"tùy chọn \"--add-or-replace\" hoặc \"--overwrite\"."

#: addrepo.cpp:454
#, c++-format
msgid ""
"File \"{}\" already exists and configures repositories with IDs \"{}\". Add "
"\"--overwrite\" to overwrite."
msgstr ""
"Tệp \"{}\" đã tồn tại và cấu hình các kho lưu trữ có ID là \"{}\". Hãy thêm "
"tùy chọn \"--overwrite\" để ghi đè."

#: addrepo.cpp:474 addrepo.cpp:500
#, c++-format
msgid "A repository with id \"{}\" already configured in file: {}"
msgstr "Một kho lưu trữ có ID \"{}\" đã được cấu hình trong tệp: {}"

#: addrepo.cpp:486 setopt.cpp:263
#, c++-format
msgid "Cannot read repositories from directory \"{}\": {}"
msgstr "Không thể đọc các kho lưu trữ từ thư mục \"{}\": {}"

#: config-manager.cpp:43
msgid "Manage configuration"
msgstr "Quản lý cấu hình"

#: setopt.cpp:91 unsetopt.cpp:72
#, c++-format
msgid ""
"{}: Badly formatted argument value: Last key character cannot be '.': {}"
msgstr ""
"{}: Giá trị đối số định dạng không đúng: Ký tự cuối cùng của khóa không được "
"là '.': {}"

#: setopt.cpp:100 unsetopt.cpp:81
#, c++-format
msgid "{}: Empty repository id is not allowed: {}"
msgstr "{}: Không được phép sử dụng ID kho trống: {}"

#: setopt.cpp:109
#, c++-format
msgid "Cannot set repository option \"{}\": {}"
msgstr "Không thể thiết lập tùy chọn kho lưu trữ \"{}\": {}"

#: setopt.cpp:116 setopt.cpp:179
#, c++-format
msgid ""
"Sets the \"{}\" option of the repository \"{}\" again with a different "
"value: \"{}\" != \"{}\""
msgstr ""
"Đặt lại tùy chọn \"{}\" của kho lưu trữ \"{}\" một lần nữa với một giá trị "
"khác: \"{}\" != \"{}\""

#: setopt.cpp:130
#, c++-format
msgid "Cannot set option: \"{}\": {}"
msgstr "Không thể đặt tùy chọn: \"{}\": {}"

#: setopt.cpp:170
#, c++-format
msgid "No matching repository to modify: {}"
msgstr "Không có kho lưu trữ phù hợp để chỉnh sửa: {}"

#: setvar.cpp:60
#, c++-format
msgid "Cannot set \"{}\": Variable \"{}\" is read-only"
msgstr "Không thể đặt \"{}\": Biến \"{}\" là chỉ đọc"

#: setvar.cpp:68
#, c++-format
msgid "Sets the \"{}\" variable again with a different value: \"{}\" != \"{}\""
msgstr "Đặt lại biến \"{}\" một lần nữa với một giá trị khác: \"{}\" != \"{}\""

#: setvar.cpp:97 unsetvar.cpp:63
msgid "Missing path to vars directory"
msgstr "Thiếu đường dẫn đến thư mục vars"

#: setvar.cpp:110
#, c++-format
msgid "Cannot write variable to file \"{}\": {}"
msgstr "Không thể ghi biến vào tệp \"{}\": {}"

#: shared.hpp:58
#, c++-format
msgid ""
"The path \"{}\" exists, but it is not a directory or a symlink to a "
"directory."
msgstr ""
"Đường dẫn \"{}\" tồn tại, nhưng nó không phải là một thư mục hoặc một liên "
"kết tượng trưng đến một thư mục."

#: shared.hpp:63
#, c++-format
msgid "The path \"{}\" exists, but it is a symlink to a non-existent object."
msgstr ""
"Đường dẫn \"{}\" tồn tại, nhưng nó là một liên kết tượng trưng đến một đối "
"tượng không tồn tại."

#: shared.hpp:69
#, c++-format
msgid ""
"Directory \"{}\" does not exist. Add \"--create-missing-dir\" to create "
"missing directories."
msgstr ""
"Thư mục \"{}\" không tồn tại. Thêm \"--create-missing-dir\" để tạo các thư "
"mục còn thiếu."

#: shared.hpp:80
#, c++-format
msgid "Variable name can contain only ASCII letters, numbers and '_': {}"
msgstr "Tên biến chỉ có thể chứa các chữ cái ASCII, số và '_': {}"

#: unsetopt.cpp:93
#, c++-format
msgid "config-manager: Request to remove unsupported repository option: {}"
msgstr ""
"config-manager: Yêu cầu loại bỏ tùy chọn kho lưu trữ không được hỗ trợ: {}"

#: unsetopt.cpp:105
#, c++-format
msgid "config-manager: Request to remove unsupported main option: {}"
msgstr "config-manager: Yêu cầu xóa tùy chọn chính không được hỗ trợ: {}"

#: unsetopt.cpp:140
#, c++-format
msgid ""
"config-manager: Request to remove main option but it is not present in the "
"config file: {}"
msgstr ""
"config-manager: Yêu cầu xóa tùy chọn chính nhưng nó không tồn tại trong tệp "
"cấu hình: {}"

#: unsetopt.cpp:152
#, c++-format
msgid ""
"config-manager: Request to remove main option but config file not found: {}"
msgstr ""
"config-manager: Yêu cầu xóa tùy chọn chính nhưng không tìm thấy tệp cấu "
"hình: {}"

#: unsetopt.cpp:186
#, c++-format
msgid ""
"config-manager: Request to remove repository option but repoid is not "
"present in the overrides: {}"
msgstr ""
"config-manager: Yêu cầu xóa tùy chọn kho lưu trữ nhưng repoid không có trong "
"danh sách ghi đè: {}"

#: unsetopt.cpp:194
#, c++-format
msgid ""
"config-manager: Request to remove repository option but it is not present in "
"the overrides: {}.{}"
msgstr ""
"config-manager: Yêu cầu xóa tùy chọn kho lưu trữ nhưng tùy chọn này không có "
"trong phần ghi đè: {}.{}"

#: unsetopt.cpp:214
#, c++-format
msgid ""
"config-manager: Request to remove repository option but file with overrides "
"not found: {}"
msgstr ""
"config-manager: Yêu cầu xóa tùy chọn kho lưu trữ nhưng không tìm thấy tệp "
"chứa các thiết lập ghi đè: {}"

#: unsetvar.cpp:69
#, c++-format
msgid ""
"config-manager: Request to remove variable but vars directory was not found: "
"{}"
msgstr "config-manager: Yêu cầu xóa biến nhưng không tìm thấy thư mục biến: {}"

#: unsetvar.cpp:82
#, c++-format
msgid ""
"config-manager: Request to remove variable but it is not present in the vars "
"directory: {}"
msgstr ""
"config-manager: Yêu cầu xóa biến nhưng biến này không tồn tại trong thư mục "
"vars: {}"

#: unsetvar.cpp:88
#, c++-format
msgid "Cannot remove variable file \"{}\": {}"
msgstr "Không thể xóa tệp biến \"{}\": {}"
