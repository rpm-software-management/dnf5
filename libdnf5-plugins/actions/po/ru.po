#: actions.cpp:237
msgid "File \"{}\" on line {}: {}"
msgstr "Файл \"{}\", строка {}: {}"

#: actions.cpp:636 actions.cpp:642 actions.cpp:648 actions.cpp:654
msgid "\"HOOK:PKG_FILTER:DIRECTION:OPTIONS:CMD\" format expected"
msgstr "Ожидается формат «HOOK:PKG_FILTER:DIRECTION:OPTIONS:CMD»"

#: actions.cpp:676
msgid "Unknown \"enabled\" option value \"{}\""
msgstr "Неизвестное значение «{}» параметра «enabled»"

#: actions.cpp:683
msgid "Unknown option \"{}\""
msgstr "Неизвестный параметр «{}»"

#: actions.cpp:711
msgid "Unknown hook \"{}\""
msgstr "Неизвестный хук «{}»"

#: actions.cpp:720
msgid ""
"Package filter can only be used in GOAL_RESOLVED, PRE_TRANS and POST_TRANS "
"hooks"
msgstr ""
"Пакетный фильтр может быть использован только в хуках GOAL_RESOLVED, "
"PRE_TRANS и POST_TRANS"

#: actions.cpp:726
msgid "Cannot use direction without package filter"
msgstr "Невозможно использовать направление без фильтра пакетов"

#: actions.cpp:740
msgid "Unknown package direction \"{}\""
msgstr "Неизвестное направление пакета «{}»"

#: actions.cpp:747
msgid "Unknown mode \"{}\""
msgstr "Неизвестный режим «{}»"

#: actions.cpp:755
msgid "Unsupported value of the \"raise_error\" option: {}"
msgstr "Неподдерживаемое значение параметра «raise_error»: {}"

#: actions.cpp:760
msgid "Missing command"
msgstr "Отсутствует команда"

#: actions.cpp:953
msgid "Synax error: Missing equal sign (=) in action output line: {}"
msgstr ""
"Синтаксическая ошибка: Отсутствует знак равенства (=) в строке вывода "
"действия: {}"

#: actions.cpp:964
msgid "Cannot set option: Action output line: {}"
msgstr "Невозможно установить параметр: Строка вывода действия: {}"

#: actions.cpp:982
msgid "Action sent the wrong log level: {}"
msgstr ""
"В результате выполнения действия был отправлен неверный уровень "
"журналирования: {}"

#: actions.cpp:987 actions.cpp:1794
msgid "Action calls for stop: {}"
msgstr "Действие требует остановки: {}"

#: actions.cpp:990 actions.cpp:1801
msgid "Action sent error message: {}"
msgstr "Действием было отправлено сообщение об ошибке: {}"

#: actions.cpp:995
msgid ""
"Syntax error: Action output line must start with \"tmp.\" or \"conf.\" or "
"\"var.\" or \"stop=\" or \"error=\": {}"
msgstr ""
"Синтаксическая ошибка: строка вывода действия должна начинаться с \"tmp.\" "
"или \"conf.\" или \"var.\" или \"stop=\" или \"error=\": {}"

#: actions.cpp:1020
msgid "Error reading from action (from pipe)"
msgstr "Ошибка при чтении из действия (из канала)"

#: actions.cpp:1038
msgid "Syntax error in json request from action: Missing starting '{{' char"
msgstr ""
"Синтаксическая ошибка в JSON-запросе от действия: отсутствует начальный "
"символ '{{'"

#: actions.cpp:1062
msgid "Error during processing of a request from action."
msgstr "Ошибка при обработке запроса от действия."

#: actions.cpp:1071
msgid "Syntax error in json request from action: {}"
msgstr "Синтаксическая ошибка в JSON-запросе от действия: {}"

#: actions.cpp:1079
msgid "Syntax error in json request from action: Incomplete input"
msgstr "Синтаксическая ошибка в JSON-запросе от действия: неполный ввод"

#: actions.cpp:1154
msgid "Cannot write response"
msgstr "Невозможно записать ответ"

#: actions.cpp:1821
msgid "Actions plugin: Cannot create pipe"
msgstr "Плагин actions: невозможно создать канал"

#: actions.cpp:1913
msgid "Actions plugin: Cannot fork"
msgstr "Плагин actions: ветвление невозможно"

#: actions.cpp:1968
msgid "Actions plugin: Cannot bind command stdin"
msgstr "Плагин actons: не удается привязать команду стандартного ввода"

#: actions.cpp:1970
msgid "Actions plugin: Cannot bind command stdout"
msgstr "Плагин ations: не удается привязать команду стандартного вывода"

#: actions.cpp:1988
msgid "Cannot execute action, command \"{}\" arguments \"{}\""
msgstr "Не удается выполнить действие, аргументы «{}» команды «{}»"

#: actions.cpp:1996
msgid "Error during preparation child process"
msgstr "Ошибка во время подготовки дочернего процесса"

#: actions.cpp:2015
msgid "Exit code: {}"
msgstr "Код выхода: {}"

#: actions.cpp:2019
msgid "Terminated by signal: {}"
msgstr "Завершено сигналом: {}"

#~ msgid "Error in file \"{}\" on line {}: Unknown option \"{}\""
#~ msgstr "Ошибка в файле \"{}\" в строке {}: Неизвестный параметр \"{}\""

#~ msgid "Error in file \"{}\" on line {}: Unknown mode \"{}\""
#~ msgstr "Ошибка в файле \"{}\" в строке {}: Неизвестный режим \"{}\""

#~ msgid "Error in file \"{}\" on line {}: Missing command"
#~ msgstr "Ошибка в файле \"{}\" в строке {}: Отсутствующая команда"
